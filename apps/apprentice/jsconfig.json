{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@gradlly/ui": ["../../packages/ui/src/index.js"],
      "@gradlly/utils": ["../../packages/utils/src/index.js"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
