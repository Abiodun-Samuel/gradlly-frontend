<style>
table{border-collapse:collapse;font-family:Calibri,Arial,sans-serif;font-size:10pt}
th{background:#1F3A5F;color:#fff;padding:7px 10px;text-align:left;border:1px solid #16304f;white-space:nowrap}
td{padding:5px 10px;border:1px solid #DDD;vertical-align:top}
.sec{background:#2E5A87;color:#fff;font-weight:bold;font-size:10.5pt;padding:7px 10px}
.recsec{background:#1B7A3D;color:#fff;font-weight:bold;font-size:10.5pt;padding:7px 10px}
.st{font-weight:bold;text-align:center;white-space:nowrap}
.api{font-family:Consolas,monospace;font-size:8.5pt;color:#1F3A5F}
.pri{text-align:center;font-weight:bold;color:#555}
</style></head><body>
